# Copy this file to .env and fill in your keys. .env is gitignored.

# Gemini API key (Google AI Studio: https://aistudio.google.com/apikey). Used for summarization.
GEMINI_API_KEY=

# Optional: NCBI E-utilities API key (https://www.ncbi.nlm.nih.gov/account/settings/).
# Raises PubMed rate limit from 3 to 10 requests/sec. Leave blank if you don't have one.
NCBI_API_KEY=

# Optional: contact email for NCBI/OpenAlex polite pool. Recommended.
NCBI_EMAIL=

# Optional overrides
GEMINI_MODEL=gemini-3.5-flash
VAULT_REFERENCES_DIR=C:/path/to/YourVault/References

# Destination for `npm run deploy` (the plugin folder inside your vault).
# If unset, derived from VAULT_REFERENCES_DIR.
VAULT_PLUGIN_DIR=C:/path/to/YourVault/.obsidian/plugins/rag-obsidian
